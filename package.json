{
  "name": "issy-assistant",
  "version": "1.0.0",
  "description": "Issy — Assistente IA WhatsApp para Corretores de Seguros",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -P tsconfig.server.json src/index.ts",
    "dev:web": "next dev --port 3001",
    "build": "npx prisma generate && tsc -p tsconfig.server.json",
    "build:web": "npx prisma generate && next build",
    "start": "node dist/index.js",
    "start:web": "next start --port 3001",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:status": "npx prisma migrate status",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@tailwindcss/postcss": "^4.2.1",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "next": "^16.1.6",
    "openai": "^4.67.0",
    "pg": "^8.18.0",
    "prisma": "^7.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.7",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "postcss": "^8.5.8",
    "ts-node-dev": "^2.0.0",
    "vitest": "^4.0.18"
  }
}
